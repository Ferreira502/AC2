#programa 1 usar add addi, sub, logicas 
# a = 2; b = 3; c = 4; d = 5; 
# x = (a+b) - (c+d); 
# y = a – b + x; 
# b = x – y; 

addi $s0, $zero, 2 # a = 2
addi $s1, $zero, 3 # b = 3
addi $s2, $zero, 4 # c = 4
addi $s3, $zero, 5 # d = 5

add $t1, $s0, $s1 # a + b
add $t2, $s2, $s3 # c + d

sub $s4, $t1, $t2 # x = t1 - t2

sub $t3, $s0, $s1 # y = a -b
add $s5, $t3, $s4 # a - b + x

sub $s1, $s4, $s5 # b = x - y