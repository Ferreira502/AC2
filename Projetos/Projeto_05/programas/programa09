# Considere a memoria incial da seguinte forma

# .data
# x1: .word 15
# x2: .word 25
# x3: .word 13
# x4: .word 17
# soma: .word -1

lw $t1, 0  		# $t1 = x1 = 15
lw $t2, 4 		# $t2 = x2 = 25
lw $t3, 8 		# $t3 = x3 = 13
lw $t4, 12 		# $t4 = x4 = 17

add $t5, $t1, $t2     	# $t5 = 15 + 25 = 40
add  $t5, $t5, $t3  	# $t5 = 40 + 13 = 53
add  $t5, $t5, $t4  	# $t5 = 53 + 17 = 70

sw   $t5, 16($t0)    	# soma = 70